---

const { settings, title, content } = Astro.props

---

<section class="bs-container py-6 flex flex-col items-center justify-center min-h-[70svh]">

  <!-- Content -->
  <div class="flex flex-col gap-6 max-w-xl w-full text-center items-center">

    <!-- Title -->
    <h1 class="font-display text-3xl md:text-4xl lg:text-5xl tracking-tight font-semibold" set:html={ title } />

    <!-- Content -->
    <div class="text-base text-bs-foreground-dark max-w-md leading-relaxed" set:html={ content } />

    <!-- CTA -->
    <button type="button" class="bs-btn self-center mt-4" onclick="demo.showModal()">
      { settings.demo.cta }
    </button>

  </div>

</section>
